FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy

WORKDIR /workspace

COPY pyproject.toml uv.lock README.md LICENSE.txt /workspace/

RUN uv sync --frozen --no-dev --no-install-project

COPY . /workspace

RUN uv sync --frozen --no-dev

RUN /workspace/.venv/bin/python - <<'PY'
import importlib.metadata
import subprocess
import sys

installed = sorted(
    {
        dist.metadata["Name"]
        for dist in importlib.metadata.distributions()
        if dist.metadata["Name"].startswith("nvidia-")
        or dist.metadata["Name"] in {"torch", "triton"}
    }
)
if installed:
    subprocess.check_call(
        ["uv", "pip", "uninstall", "--python", sys.executable, *installed]
    )
subprocess.check_call(
    [
        "uv",
        "pip",
        "install",
        "--python",
        sys.executable,
        "--no-cache-dir",
        "--index-url",
        "https://download.pytorch.org/whl/cpu",
        "torch==2.8.0",
    ]
)
PY

RUN /workspace/.venv/bin/python - <<'PY'
import pathlib
import shutil
import site

src = pathlib.Path("/workspace/.rar/sdk/redis_agent_kit")
if not src.is_dir():
    raise RuntimeError("missing injected redis_agent_kit SDK source")
target = pathlib.Path(site.getsitepackages()[0]) / "redis_agent_kit"
if target.exists():
    shutil.rmtree(target)
shutil.copytree(src, target)
PY

RUN rm -rf /root/.cache /workspace/.cache

FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/workspace/.venv/bin:$PATH"

WORKDIR /workspace

COPY --from=builder /workspace /workspace

CMD ["python", "runtime_agent.py"]
