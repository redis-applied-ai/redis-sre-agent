FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /workspace

COPY . /workspace

RUN python -m pip install --no-cache-dir --upgrade pip
RUN python - <<'PY'
import subprocess
import sys
deps = [
    "cryptography>=45.0.0,<46",
    "langchain-core>=0.3.25",
    "mcp>=1.23.3",
    "pydantic>=2.0.0",
    "pydantic-settings>=2.0.0",
    "PyYAML>=6.0.0",
    "python-dotenv>=1.0.0",
    "python-ulid>=3.0.0",
    "redis>=4.5.0",
    "redisvl>=0.9.0,<1.0",
]
subprocess.check_call([sys.executable, "-m", "pip", "install", "--no-cache-dir", *deps])
PY
RUN python - <<'PY'
import pathlib
import shutil
import site

src = pathlib.Path("/workspace/.rar/sdk/redis_agent_kit")
if not src.is_dir():
    raise RuntimeError("missing injected redis_agent_kit SDK source")
target = pathlib.Path(site.getsitepackages()[0]) / "redis_agent_kit"
if target.exists():
    shutil.rmtree(target)
shutil.copytree(src, target)
PY

CMD ["python", "runtime_agent.py"]
